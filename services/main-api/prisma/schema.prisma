  @@index([pricing_table_id], map: "idx_pricing_param_table")
  @@map("pricing_params")
  @@schema("core")
}

/// Tham số định giá GIAO HÀNG: theo kg, CBM (D×R×C)/6000, size S/M/L/XL/BULKY
/// Công thức: chargeable_kg = max(actual_kg, volumetric_kg); volumetric_kg = (D×R×C)/cbm_divisor
model DeliveryPricingParam {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pricing_table_id String   @map("pricing_table_id") @db.Uuid
  size_tier        delivery_size_tier @map("size_tier")
  base_fee         BigInt   @map("base_fee")
  per_kg           BigInt   @map("per_kg")
  cbm_divisor      Int      @default(6000) @map("cbm_divisor")
  factors          Json?    @default("{}")
  is_active        Boolean  @default(true) @map("is_active")
  created_at       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  pricing_table PricingTable @relation(fields: [pricing_table_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([pricing_table_id, size_tier], map: "uq_delivery_param_table_size")
  @@index([pricing_table_id], map: "idx_delivery_param_table")
  @@map("delivery_pricing_params")
  @@schema("core")
}

