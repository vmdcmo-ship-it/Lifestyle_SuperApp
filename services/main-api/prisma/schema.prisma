// ══════════════════════════════════════════════════════════════════════════════
// INSURANCE: Products, Policies, Claims
// ══════════════════════════════════════════════════════════════════════════════

model InsuranceProduct {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productCode     String             @unique @map("product_code") @db.VarChar(30)
  name            String             @db.VarChar(300)
  type            insurance_type
  provider        String             @db.VarChar(200)
  description     String?
  coverageDetails Json?              @map("coverage_details") @default("{}")
  premiumMonthly  BigInt             @map("premium_monthly")
  premiumYearly   BigInt             @map("premium_yearly")
  coverageAmount  BigInt             @map("coverage_amount")
  currency        String             @default("VND") @db.VarChar(10)
  termMonths      Int                @map("term_months")
  minAge          Int?               @map("min_age")
  maxAge          Int?               @map("max_age")
  isActive        Boolean            @default(true) @map("is_active")
  metadata        Json?              @default("{}")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  policies        InsurancePolicy[]

  @@index([type], map: "idx_ins_products_type")
  @@map("insurance_products")
  @@schema("insurance")
}

model InsurancePolicy {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  policyNumber     String           @unique @map("policy_number") @db.VarChar(30)
  userId           String           @map("user_id") @db.Uuid
  productId        String           @map("product_id") @db.Uuid
  status           policy_status    @default(PENDING)
  premiumAmount    BigInt           @map("premium_amount")
  coverageAmount   BigInt           @map("coverage_amount")
  currency         String           @default("VND") @db.VarChar(10)
  startDate        DateTime         @map("start_date") @db.Date
  endDate          DateTime         @map("end_date") @db.Date
  beneficiaryName  String?          @map("beneficiary_name") @db.VarChar(200)
  beneficiaryPhone String?          @map("beneficiary_phone") @db.VarChar(20)
  metadata         Json?            @default("{}")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  product          InsuranceProduct @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  claims           InsuranceClaim[]

  @@index([userId], map: "idx_ins_policies_user")
  @@index([status], map: "idx_ins_policies_status")
  @@map("insurance_policies")
  @@schema("insurance")
}

model InsuranceClaim {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  claimNumber   String          @unique @map("claim_number") @db.VarChar(30)
  policyId      String          @map("policy_id") @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  status        claim_status    @default(SUBMITTED)
  claimAmount   BigInt          @map("claim_amount")
  approvedAmount BigInt?        @map("approved_amount")
  currency      String          @default("VND") @db.VarChar(10)
  reason        String
  description   String?
  documents     String[]        @default([])
  reviewNote    String?         @map("review_note")
  reviewedAt    DateTime?       @map("reviewed_at") @db.Timestamptz(6)
  paidAt        DateTime?       @map("paid_at") @db.Timestamptz(6)
  metadata      Json?           @default("{}")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  policy        InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId], map: "idx_ins_claims_user")
  @@index([policyId], map: "idx_ins_claims_policy")
  @@map("insurance_claims")
  @@schema("insurance")
}

enum insurance_type {
  HEALTH
  LIFE
  VEHICLE
  TRAVEL
  HOME
  ACCIDENT
  SOCIAL

  @@schema("insurance")
}

enum policy_status {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED

  @@schema("insurance")
}

enum claim_status {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PAID
  CANCELLED

  @@schema("insurance")
}
