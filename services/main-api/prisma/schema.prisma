  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  referrer User @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referee  User @relation("ReferralReferee", fields: [refereeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([referrerId], map: "idx_referrals_referrer")
  @@index([refereeId], map: "idx_referrals_referee")
  @@map("referrals")
  @@schema("core")
}

// ══════════════════════════════════════════════════════════════════════════════
// LUCKY WHEEL: Vòng quay may mắn – khuyến mãi động cho Tài xế & User
// ══════════════════════════════════════════════════════════════════════════════

model LuckyWheelCampaign {
  id                       String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                     String                  @db.VarChar(200)
  description              String?
  status                   lucky_wheel_campaign_status @default(DRAFT)
  startDate                DateTime                @map("start_date") @db.Timestamptz(6)
  endDate                  DateTime                @map("end_date") @db.Timestamptz(6)
  budget                   BigInt                  @default(0)
  budgetUsed               BigInt                  @default(0) @map("budget_used")
  driverRevenuePerSpin     Int                     @default(100000) @map("driver_revenue_per_spin")
  userTopUpPerSpin         Int                     @default(500000) @map("user_top_up_per_spin")
  userOrderPerSpin         Int                     @default(1) @map("user_order_per_spin")
  metadata                 Json?                   @default("{}")
  createdAt                DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  prizes                   LuckyWheelPrize[]
  creditGrants             LuckyWheelCreditGrant[]
  spins                    LuckyWheelSpin[]
  creditBalances           LuckyWheelCreditBalance[]

  @@index([status], map: "idx_lw_campaigns_status")
  @@index([startDate, endDate], map: "idx_lw_campaigns_dates")
  @@map("lucky_wheel_campaigns")
  @@schema("core")
}

enum lucky_wheel_campaign_status {
  DRAFT
  ACTIVE
  PAUSED
  ENDED

  @@schema("core")
}

enum lucky_wheel_prize_type {
  VOUCHER
  WALLET_CREDIT
  PHYSICAL_GOODS
  NO_PRIZE

  @@schema("core")
}

model LuckyWheelPrize {
  id               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId       String                 @map("campaign_id") @db.Uuid
  name             String                 @db.VarChar(200)
  type             lucky_wheel_prize_type
  weight           Int                    @default(1)
  quantity         Int?                   @map("quantity")
  quantityGiven    Int                    @default(0) @map("quantity_given")
  valueJson        Json?                   @map("value_json")
  metadata         Json?                   @default("{}")
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  campaign         LuckyWheelCampaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  spins            LuckyWheelSpin[]

  @@index([campaignId], map: "idx_lw_prizes_campaign")
  @@map("lucky_wheel_prizes")
  @@schema("core")
}

enum lucky_wheel_credit_source {
  BOOKING_REVENUE
  ORDER
  TOP_UP

  @@schema("core")
}

model LuckyWheelCreditGrant {
  id               String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId       String                    @map("campaign_id") @db.Uuid
  userId           String                    @map("user_id") @db.Uuid
  participantType  lucky_wheel_participant   @map("participant_type")
  source           lucky_wheel_credit_source
  sourceId         String?                   @map("source_id") @db.VarChar(100)
  amount           BigInt                    @default(0)
  creditsGranted   Int                       @map("credits_granted")
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  campaign         LuckyWheelCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([campaignId, userId], map: "idx_lw_credit_grants_campaign_user")
  @@index([source, sourceId], map: "idx_lw_credit_grants_source")
  @@map("lucky_wheel_credit_grants")
  @@schema("core")
}

enum lucky_wheel_participant {
  USER
  DRIVER

  @@schema("core")
}

model LuckyWheelCreditBalance {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId       String                @map("campaign_id") @db.Uuid
  userId           String                @map("user_id") @db.Uuid
  participantType  lucky_wheel_participant @map("participant_type")
  balance          Int                    @default(0)
  updatedAt        DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  campaign         LuckyWheelCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([campaignId, userId, participantType], map: "uq_lw_credit_balance_campaign_user")
  @@index([campaignId], map: "idx_lw_credit_balances_campaign")
  @@map("lucky_wheel_credit_balances")
  @@schema("core")
}

model LuckyWheelSpin {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId       String             @map("campaign_id") @db.Uuid
  userId           String             @map("user_id") @db.Uuid
  participantType  lucky_wheel_participant @map("participant_type")
  prizeId          String?            @map("prize_id") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  campaign         LuckyWheelCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  prize            LuckyWheelPrize?   @relation(fields: [prizeId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([campaignId], map: "idx_lw_spins_campaign")
  @@index([userId, campaignId], map: "idx_lw_spins_user_campaign")
  @@index([createdAt(sort: Desc)], map: "idx_lw_spins_created")
  @@map("lucky_wheel_spins")
  @@schema("core")
}

// ══════════════════════════════════════════════════════════════════════════════
// RUN TO EARN: Chạy kiếm tiền (chỉ App User)
// ══════════════════════════════════════════════════════════════════════════════

model RunToEarnCampaign {
  id                String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String                   @db.VarChar(200)
  description       String?                  @db.Text
  status            run_to_earn_status       @default(DRAFT)
  startDate         DateTime                 @map("start_date") @db.Timestamptz(6)
  endDate           DateTime                 @map("end_date") @db.Timestamptz(6)
  stepsPerXu        Int                      @default(1000) @map("steps_per_xu")
  budget            BigInt                   @default(0)
  budgetUsed        BigInt                   @default(0) @map("budget_used")
  metadata          Json?                    @default("{}")
  createdAt         DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  prizes            RunToEarnPrize[]
  participations    RunToEarnParticipation[]

  @@index([status], map: "idx_rte_campaigns_status")
  @@index([startDate, endDate], map: "idx_rte_campaigns_dates")
  @@map("run_to_earn_campaigns")
  @@schema("core")
}

enum run_to_earn_status {
  DRAFT
  ACTIVE
  PAUSED
  ENDED

  @@schema("core")
}

model RunToEarnPrize {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId  String               @map("campaign_id") @db.Uuid
  name        String               @db.VarChar(200)
  type        run_to_earn_prize_type
  rankFrom    Int                  @map("rank_from")
  rankTo      Int                  @map("rank_to")
  xuAmount    Int?                 @map("xu_amount")
  couponId    String?              @map("coupon_id") @db.Uuid
  valueJson   Json?                @map("value_json")
  quantity    Int                  @default(1)
  quantityGiven Int                @default(0) @map("quantity_given")
  campaign    RunToEarnCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([campaignId], map: "idx_rte_prizes_campaign")
  @@map("run_to_earn_prizes")
  @@schema("core")
}

enum run_to_earn_prize_type {
  XU
  VOUCHER
  PHYSICAL_GOODS

  @@schema("core")
}

model RunToEarnParticipation {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId  String               @map("campaign_id") @db.Uuid
  userId      String               @map("user_id") @db.Uuid
  totalSteps  Int                  @default(0) @map("total_steps")
  rank        Int?                 @map("rank")
  prizeId     String?              @map("prize_id") @db.Uuid
  xuEarned    Int                  @default(0) @map("xu_earned")
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  campaign    RunToEarnCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([campaignId, userId], map: "uq_rte_participation_campaign_user")
  @@index([campaignId], map: "idx_rte_participation_campaign")
  @@index([userId], map: "idx_rte_participation_user")
  @@map("run_to_earn_participations")
  @@schema("core")
}

