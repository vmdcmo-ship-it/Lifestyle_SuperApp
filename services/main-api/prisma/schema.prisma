/// Tham số định giá GỌI XE (base_fare, per_km, per_min...)
/// factors Json: { surgeEnabled, surgeMax, weatherEnabled, weatherMultiplier, trafficEnabled, trafficMultiplier }
model PricingParam {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pricing_table_id String   @map("pricing_table_id") @db.Uuid
  vehicle_type     String   @map("vehicle_type") @db.VarChar(30)
  base_fare        BigInt   @map("base_fare")
  per_km           BigInt   @map("per_km")
  per_min          BigInt   @map("per_min")
  min_fare         BigInt   @map("min_fare")
  factors          Json?    @default("{}")
  is_active        Boolean  @default(true) @map("is_active")
  created_at       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  pricing_table PricingTable @relation(fields: [pricing_table_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

