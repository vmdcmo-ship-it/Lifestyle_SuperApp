  updated_at DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  parent   Region?              @relation("RegionHierarchy", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
