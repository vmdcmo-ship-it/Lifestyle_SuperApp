generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["core", "driver", "merchant", "payment", "spotlight", "insurance"]
}

model User {
  id                                                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                              String               @db.VarChar(255)
  phoneNumber                                        String?              @map("phone_number") @db.VarChar(20)
  passwordHash                                       String               @map("password_hash") @db.VarChar(255)
  firstName                                          String               @map("first_name") @db.VarChar(100)
  lastName                                           String               @map("last_name") @db.VarChar(100)
  displayName                                        String               @map("display_name") @db.VarChar(200)
  avatar_url                                         String?
  dateOfBirth                                        DateTime?            @map("date_of_birth") @db.Date
  gender                                             gender?
  isEmailVerified                                    Boolean              @default(false) @map("is_email_verified")
  isPhoneVerified                                    Boolean              @default(false) @map("is_phone_verified")
  isActive                                           Boolean              @default(true) @map("is_active")
  ekycLevel                                          ekyc_level           @default(LEVEL_0) @map("ekyc_level")
  ekyc_verified_at                                   DateTime?            @db.Timestamptz(6)
  role                                               user_role            @default(CUSTOMER)
  lastLoginAt                                        DateTime?            @map("last_login_at") @db.Timestamptz(6)
  login_count                                        Int                  @default(0)
  preferences                                        Json?                @default("{\"theme\": \"AUTO\", \"currency\": \"VND\", \"language\": \"vi\", \"notifications\": {\"sms\": true, \"push\": true, \"email\": true}}")
  xuBalance                                          BigInt               @default(0) @map("xu_balance")
  referralCode                                       String?              @unique @map("referral_code") @db.VarChar(20)
  referred_by                                        String?              @db.Uuid
  metadata                                           Json?                @default("{}")
  mfa_enabled                                        Boolean              @default(false) @map("mfa_enabled")
  mfa_secret                                         String?              @map("mfa_secret") @db.VarChar(64)
  createdAt                                          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                          DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                                          DateTime?            @map("deleted_at") @db.Timestamptz(6)
  authTokens                                         AuthToken[]
  social_connections                                 social_connections[]
  addresses                                          UserAddress[]
  users                                              User?                @relation("usersTousers", fields: [referred_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_users                                        User[]               @relation("usersTousers")
  driver                                             Driver?
  merchant_staff                                     merchant_staff[]
  merchants                                          merchants[]
  bank_accounts                                      bank_accounts[]
  transactions_transactions_recipient_user_idTousers Transaction[]        @relation("transactions_recipient_user_idTousers")
  transactions_transactions_user_idTousers           Transaction[]        @relation("transactions_user_idTousers")
  wallets                                            Wallet?
  comments                                           Comment[]
  creator                                            Creator?
  reviews                                            Review[]
  referralsAsReferrer                                Referral[]           @relation("ReferralReferrer")
  referralsAsReferee                                 Referral[]           @relation("ReferralReferee")
  redcomment_saves                                   RedcommentSave[]
  creator_follows                                    CreatorFollow[]

  @@index([createdAt(sort: Desc)], map: "idx_users_created")
  @@index([displayName(ops: raw("gin_trgm_ops"))], map: "idx_users_display_name_trgm", type: Gin)
  @@index([ekycLevel], map: "idx_users_ekyc")
  @@index([role], map: "idx_users_role")
  @@map("users")
  @@schema("core")
}

model AuthToken {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  refresh_token String    @unique @db.VarChar(500)
  deviceInfo    Json?     @map("device_info")
  ipAddress     String?   @map("ip_address") @db.Inet
  user_agent    String?
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(6)
  revoked_at    DateTime? @db.Timestamptz(6)
  isRevoked     Boolean   @default(false) @map("is_revoked")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([refresh_token], map: "idx_auth_tokens_token")
  @@index([userId], map: "idx_auth_tokens_user")
  @@map("auth_tokens")
  @@schema("core")
}

model UserAddress {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  label       String   @default("Home") @db.VarChar(50)
  street      String   @db.VarChar(500)
  ward        String?  @db.VarChar(200)
  district    String?  @db.VarChar(200)
  city        String   @db.VarChar(200)
  country     String   @default("Vietnam") @db.VarChar(100)
  postal_code String?  @db.VarChar(20)
  latitude    Decimal? @db.Decimal(10, 8)
  longitude   Decimal? @db.Decimal(11, 8)
  fullAddress String   @map("full_address")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_user_addresses_user")
  @@map("user_addresses")
  @@schema("core")
}

model Driver {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String             @unique @map("user_id") @db.Uuid
  driverNumber         String             @unique @map("driver_number") @db.VarChar(20)
  status               driver_status      @default(PENDING_VERIFICATION)
  onlineStatus         online_status      @default(OFFLINE) @map("online_status")
  currentLat           Decimal?           @map("current_lat") @db.Decimal(10, 8)
  currentLng           Decimal?           @map("current_lng") @db.Decimal(11, 8)
  lastLocationAt       DateTime?          @map("last_location_at") @db.Timestamptz(6)
  totalTrips           Int                @default(0) @map("total_trips")
  totalDistanceKm      Decimal            @default(0) @map("total_distance_km") @db.Decimal(12, 2)
  rating               Decimal            @default(5.00) @db.Decimal(3, 2)
  total_ratings        Int                @default(0)
  acceptanceRate       Decimal            @default(100.00) @map("acceptance_rate") @db.Decimal(5, 2)
  cancellation_rate    Decimal            @default(0.00) @db.Decimal(5, 2)
  totalEarnings        BigInt             @default(0) @map("total_earnings")
  current_balance      BigInt             @default(0)
  verified_at          DateTime?          @db.Timestamptz(6)
  verified_by          String?            @db.Uuid
  rejection_reason     String?
  onboarding_step      Int                @default(1)
  onboarding_completed Boolean            @default(false)
  metadata             Json?              @default("{}")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?          @map("deleted_at") @db.Timestamptz(6)
  driver_identities    driver_identities?
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vehicles             Vehicle[]

  @@index([createdAt(sort: Desc)], map: "idx_drivers_created")
  @@index([driverNumber], map: "idx_drivers_number")
  @@index([rating(sort: Desc)], map: "idx_drivers_rating")
  @@index([status], map: "idx_drivers_status")
  @@index([userId], map: "idx_drivers_user_id")
  @@map("drivers")
  @@schema("driver")
}

model Vehicle {
  id                      String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  driverId                String              @map("driver_id") @db.Uuid
  vehicleType             vehicle_type        @map("vehicle_type")
  vehicle_class           String?             @map("vehicle_class") @db.VarChar(50)
  licensePlate            String              @map("license_plate") @db.VarChar(20)
  brand                   String              @db.VarChar(100)
  model                   String              @db.VarChar(100)
  year                    Int                 @db.SmallInt
  color                   String              @db.VarChar(50)
  front_image             String
  back_image              String
  left_image              String
  right_image             String
  plate_closeup_image     String
  registration_number     String              @db.VarChar(50)
  registration_issue_date DateTime            @db.Date
  registration_expiry     DateTime?           @db.Date
  registration_image      String
  insurance_number        String              @db.VarChar(50)
  insurance_provider      String              @db.VarChar(200)
  insurance_issue_date    DateTime            @db.Date
  insurance_expiry        DateTime            @db.Date
  insurance_image         String
  inspection_number       String?             @map("inspection_number") @db.VarChar(50)
  inspection_issue_date   DateTime?           @map("inspection_issue_date") @db.Date
  inspection_expiry       DateTime?           @map("inspection_expiry") @db.Date
  verification_status     verification_status @default(PENDING)
  verified_at             DateTime?           @db.Timestamptz(6)
  verified_by             String?             @db.Uuid
  rejection_reason        String?
  is_primary              Boolean             @default(true)
  isActive                Boolean             @default(true) @map("is_active")
  createdAt               DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  driver                  Driver              @relation(fields: [driverId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([driverId], map: "idx_vehicles_driver")
  @@index([insurance_expiry], map: "idx_vehicles_insurance_expiry")
  @@index([vehicleType], map: "idx_vehicles_type")
  @@map("vehicles")
  @@schema("driver")
}

model Booking {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingNumber   String         @unique @map("booking_number") @db.VarChar(30)
  userId          String         @map("user_id") @db.Uuid
  driverId        String?        @map("driver_id") @db.Uuid
  status          booking_status @default(SEARCHING_DRIVER)
  vehicleType     vehicle_type   @map("vehicle_type")
  pickupLat       Decimal        @map("pickup_lat") @db.Decimal(10, 8)
  pickupLng       Decimal        @map("pickup_lng") @db.Decimal(11, 8)
  pickupAddress   String         @map("pickup_address")
  dropoffLat      Decimal        @map("dropoff_lat") @db.Decimal(10, 8)
  dropoffLng      Decimal        @map("dropoff_lng") @db.Decimal(11, 8)
  dropoffAddress  String         @map("dropoff_address")
  distanceKm      Decimal        @map("distance_km") @db.Decimal(8, 2)
  durationMin     Int            @map("duration_min")
  basePrice       BigInt         @map("base_price")
  distancePrice   BigInt         @map("distance_price")
  timePrice       BigInt         @map("time_price")
  totalPrice      BigInt         @map("total_price")
  surgeMultiplier Decimal        @default(1.0) @map("surge_multiplier") @db.Decimal(3, 1)
  currency        String         @default("VND") @db.VarChar(10)
  paymentMethod   payment_method? @map("payment_method")
  note            String?
  cancelReason    String?        @map("cancel_reason")
  cancelledBy     String?        @map("cancelled_by") @db.VarChar(20)
  rating          Decimal?       @db.Decimal(3, 1)
  ratingComment   String?        @map("rating_comment")
  ratedAt         DateTime?      @map("rated_at") @db.Timestamptz(6)
  acceptedAt      DateTime?      @map("accepted_at") @db.Timestamptz(6)
  pickedUpAt      DateTime?      @map("picked_up_at") @db.Timestamptz(6)
  completedAt     DateTime?      @map("completed_at") @db.Timestamptz(6)
  cancelledAt     DateTime?      @map("cancelled_at") @db.Timestamptz(6)
  metadata        Json?          @default("{}")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId], map: "idx_bookings_user")
  @@index([driverId], map: "idx_bookings_driver")
  @@index([status], map: "idx_bookings_status")
  @@index([bookingNumber], map: "idx_bookings_number")
  @@index([createdAt(sort: Desc)], map: "idx_bookings_created")
  @@map("bookings")
  @@schema("driver")
}

model FareConfig {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleType   String   @unique @map("vehicle_type") @db.VarChar(30)
  baseFare      BigInt   @map("base_fare")
  perKm         BigInt   @map("per_km")
  perMin        BigInt   @map("per_min")
  minFare       BigInt   @map("min_fare")
  isActive      Boolean  @default(true) @map("is_active")
  effectiveFrom DateTime @default(now()) @map("effective_from") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([vehicleType], map: "idx_fare_config_vehicle")
  @@map("fare_config")
  @@schema("driver")
}

model Creator {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String             @unique @map("user_id") @db.Uuid
  creator_number      String             @unique @db.VarChar(20)
  affiliate_id        String             @unique @db.VarChar(20)
  display_name        String             @db.VarChar(200)
  bio                 String?
  avatar_url          String?
  cover_url           String?
  tier                creator_tier       @default(NEWCOMER)
  follower_count      Int                @default(0)
  following_count     Int                @default(0)
  totalViews          BigInt             @default(0) @map("total_views")
  totalLikes          BigInt             @default(0) @map("total_likes")
  total_redcomments   Int                @default(0)
  total_earned        BigInt             @default(0)
  pending_payout      BigInt             @default(0)
  avg_content_rating  Decimal            @default(0.00) @db.Decimal(3, 2)
  phone               String?            @db.VarChar(20)
  email               String?            @db.VarChar(255)
  social_links        Json?              @default("{}")
  bank_name           String?            @db.VarChar(200)
  bank_account_number String?            @db.VarChar(30)
  bank_account_holder String?            @db.VarChar(200)
  is_active           Boolean            @default(true)
  isVerified          Boolean            @default(false) @map("is_verified")
  verified_at         DateTime?          @db.Timestamptz(6)
  categories          String[]           @default([])
  metadata            Json?              @default("{}")
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  creator_earnings    creator_earnings[]
  creator_follows     CreatorFollow[]
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  redcomments         Redcomment[]

  @@index([affiliate_id], map: "idx_creators_affiliate")
  @@index([follower_count(sort: Desc)], map: "idx_creators_followers")
  @@index([creator_number], map: "idx_creators_number")
  @@index([tier], map: "idx_creators_tier")
  @@index([userId], map: "idx_creators_user")
  @@map("creators")
  @@schema("spotlight")
}

model SpotlightCategory {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug       String       @unique @db.VarChar(100)
  name       String       @db.VarChar(200)
  order      Int          @default(0) @db.SmallInt
  is_active  Boolean      @default(true) @map("is_active")
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  redcomments Redcomment[]

  @@index([slug], map: "idx_spotlight_categories_slug")
  @@map("spotlight_categories")
  @@schema("spotlight")
}

model Redcomment {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  redcommentNumber      String             @unique @map("redcomment_number") @db.VarChar(30)
  creatorId             String             @map("creator_id") @db.Uuid
  spotlight_category_id String?            @map("spotlight_category_id") @db.Uuid
  format                redcomment_format
  title                 String             @db.VarChar(300)
  description           String?
  video_url             String?
  video_source          String?             @map("video_source") @db.VarChar(20)
  videoDuration         Int?               @map("video_duration") @db.SmallInt
  thumbnailUrl          String?            @map("thumbnail_url")
  photo_urls            String[]
  cover_image_url       String
  targetType       target_type        @map("target_type")
  target_id        String?            @db.Uuid
  target_name      String             @db.VarChar(300)
  target_tags      String[]
  merchant_id      String?            @db.Uuid
  overall_rating   Decimal            @db.Decimal(3, 1)
  category_ratings Json?
  seo_slug         String             @unique @db.VarChar(300)
  seoTitle         String?            @map("seo_title") @db.VarChar(200)
  seoDescription   String?            @map("seo_description") @db.VarChar(500)
  seo_keywords     String[]
  ai_transcript    String?
  views            BigInt             @default(0)
  likes            BigInt             @default(0)
  shares           Int                @default(0)
  comments_count   Int                @default(0)
  saves            Int                @default(0)
  clicks           Int                @default(0)
  conversions      Int                @default(0)
  revenue          BigInt             @default(0)
  status           content_status     @default(DRAFT)
  rejection_reason rejection_reason?
  rejection_note   String?
  moderator_id     String?            @db.Uuid
  moderated_at     DateTime?          @db.Timestamptz(6)
  is_sponsored     Boolean            @default(false)
  sponsor_name     String?            @db.VarChar(200)
  is_featured      Boolean            @default(false)
  is_pinned        Boolean            @default(false)
  metadata         Json?              @default("{}")
  publishedAt      DateTime?          @map("published_at") @db.Timestamptz(6)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?          @map("deleted_at") @db.Timestamptz(6)
  comments          Comment[]
  creator_earnings  creator_earnings[]
  cta_buttons       cta_buttons[]
  creator           Creator            @relation(fields: [creatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  merchants         merchants?         @relation(fields: [merchant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  spotlight_category SpotlightCategory? @relation(fields: [spotlight_category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  redcomment_regions RedcommentRegion[]
  redcomment_saves   RedcommentSave[]

  @@index([createdAt(sort: Desc)], map: "idx_redcomments_created")
  @@index([spotlight_category_id], map: "idx_redcomments_category")
  @@index([creatorId], map: "idx_redcomments_creator")
  @@index([format], map: "idx_redcomments_format")
  @@index([redcommentNumber], map: "idx_redcomments_number")
  @@index([seo_slug], map: "idx_redcomments_slug")
  @@index([status], map: "idx_redcomments_status")
  @@index([targetType, target_id], map: "idx_redcomments_target")
  @@index([title(ops: raw("gin_trgm_ops"))], map: "idx_redcomments_title_trgm", type: Gin)
  @@index([views(sort: Desc)], map: "idx_redcomments_views")
  @@map("redcomments")
  @@schema("spotlight")
}

model Review {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewNumber         String         @unique @map("review_number") @db.VarChar(30)
  userId               String         @map("user_id") @db.Uuid
  is_verified_purchase Boolean        @default(false)
  targetType           target_type    @map("target_type")
  targetId             String?        @map("target_id") @db.Uuid
  target_name          String         @db.VarChar(300)
  merchant_id          String?        @db.Uuid
  overall_rating       Decimal        @db.Decimal(3, 1)
  title                String?        @db.VarChar(200)
  body                 String
  photo_urls           String[]
  video_url            String?
  likes                Int            @default(0)
  merchant_reply       String?
  merchant_reply_at    DateTime?      @db.Timestamptz(6)
  status               content_status @default(PENDING_REVIEW)
  metadata             Json?          @default("{}")
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?      @map("deleted_at") @db.Timestamptz(6)
  merchants            merchants?     @relation(fields: [merchant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                 User           @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([createdAt(sort: Desc)], map: "idx_reviews_created")
  @@index([reviewNumber], map: "idx_reviews_number")
  @@index([overall_rating(sort: Desc)], map: "idx_reviews_rating")
  @@index([status], map: "idx_reviews_status")
  @@index([targetType, targetId], map: "idx_reviews_target")
  @@index([userId], map: "idx_reviews_user")
  @@map("reviews")
  @@schema("spotlight")
}

model Comment {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  redcommentId   String     @map("redcomment_id") @db.Uuid
  userId         String     @map("user_id") @db.Uuid
  parentId       String?    @map("parent_id") @db.Uuid
  body           String
  likes          Int        @default(0)
  is_hidden      Boolean    @default(false)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  comments       Comment?   @relation("commentsTocomments", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_comments Comment[]  @relation("commentsTocomments")
  redcomment     Redcomment @relation(fields: [redcommentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           User       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([redcommentId], map: "idx_comments_redcomment")
  @@index([userId], map: "idx_comments_user")
  @@map("comments")
  @@schema("spotlight")
}

model RedcommentRegion {
  redcomment_id String   @map("redcomment_id") @db.Uuid
  region_id     String   @map("region_id") @db.Uuid
  redcomment    Redcomment @relation(fields: [redcomment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  region        Region     @relation(fields: [region_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([redcomment_id, region_id])
  @@index([region_id], map: "idx_redcomment_regions_region")
  @@map("redcomment_regions")
  @@schema("spotlight")
}

model RedcommentSave {
  user_id       String     @map("user_id") @db.Uuid
  redcomment_id String     @map("redcomment_id") @db.Uuid
  created_at    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  user          User       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  redcomment    Redcomment @relation(fields: [redcomment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, redcomment_id])
  @@index([user_id], map: "idx_redcomment_saves_user")
  @@index([redcomment_id], map: "idx_redcomment_saves_redcomment")
  @@map("redcomment_saves")
  @@schema("spotlight")
}

model CreatorFollow {
