PORT=3020
NODE_ENV=development
# Danh sách origin (phẩy), khớp URL web mà trình duyệt dùng — bắt buộc đúng khi deploy HTTPS
CORS_ORIGIN=http://localhost:3040,https://timnhaxahoi.com

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=timnhaxahoi

# Dev: đồng bộ schema tự động (mặc định bật khi NODE_ENV !== production). Production: luôn tắt — chạy pnpm migration:run
# TYPEORM_SYNC=false

# Rate limit (mặt định nếu không set: eligibility 12/phút, auth-sync 30/phút, leads 20/phút — TTL 60s)
# THROTTLE_ELIGIBILITY_LIMIT=12
# THROTTLE_ELIGIBILITY_TTL_SEC=60
# THROTTLE_AUTH_SYNC_LIMIT=30
# THROTTLE_AUTH_SYNC_TTL_SEC=60
# THROTTLE_LEADS_CONVERT_LIMIT=20
# THROTTLE_LEADS_CONVERT_TTL_SEC=60

# Sentry (tuỳ chọn)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0

# JWT trả về trong POST /ai/eligibility-check — dùng cho GET /user/dashboard và POST /leads/convert
DASHBOARD_JWT_SECRET=thay-bang-chuoi-dai-ngau-nhien-production
# DASHBOARD_JWT_EXPIRES_IN=7d

# Assertion JWT họ C (Super App → POST /auth/sync). Secret HS256 trùng main-api AUTH_SYNC_JWT_SECRET.
# AUTH_SYNC_REQUIRE_JWT=false
# AUTH_SYNC_JWT_SECRET=
# AUTH_SYNC_JWT_ISSUER=lifestyle-main-api
# AUTH_SYNC_JWT_AUDIENCE=timnhaxahoi:auth-sync:v1
# AUTH_SYNC_JTI_CHECK=true

# Lark Base (MVP: tùy chọn — đủ biến mới gọi API)
# LARK_OPEN_API_BASE=https://open.larksuite.com/open-apis
# LARK_APP_ID=
# LARK_APP_SECRET=
# LARK_BASE_APP_TOKEN=
# LARK_BASE_TABLE_ID=
# Map key logic → field_id Bitable (JSON). Ví dụ: {"lead_segment":"fldXXX","phone":"fldYYY","email":"fldZZZ","score":"fldS","quiz_json":"fldQ","user_id":"fldU","quiz_id":"fldI","source":"fldSrc"}
# LARK_BASE_FIELD_MAP=
# Hoặc một ô text duy nhất chứa JSON string toàn bộ payload:
# LARK_BASE_SINGLE_TEXT_FIELD_ID=
