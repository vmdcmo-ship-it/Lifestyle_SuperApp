{
  "info": {
    "name": "Lifestyle Super App API",
    "description": "Complete API collection for Lifestyle Super App.\n\n**Base URL:** http://localhost:3000/api/v1\n\n**Auth:** Most endpoints require Bearer token. Login first, then token is auto-set.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "driverId", "value": "" },
    { "key": "merchantId", "value": "" },
    { "key": "walletId", "value": "" },
    { "key": "redcommentId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register (Email)",
          "request": {
            "method": "POST",
            "header": [],
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@gmail.com\",\n  \"password\": \"Test@12345\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"phoneNumber\": \"0901111111\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.data && json.data.accessToken) {",
                "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                "  pm.collectionVariables.set('userId', json.data.user.id);",
                "  pm.test('Registration successful', () => pm.response.to.have.status(201));",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Login (Email)",
          "request": {
            "method": "POST",
            "header": [],
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nguyenvana@gmail.com\",\n  \"password\": \"Admin@2026!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.data && json.data.accessToken) {",
                "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                "  pm.collectionVariables.set('userId', json.data.user.id);",
                "  pm.test('Login successful', () => pm.response.to.have.status(200));",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Login (Phone)",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"0901234567\",\n  \"password\": \"Admin@2026!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Social Login (Google)",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"google\",\n  \"accessToken\": \"ya29.a0AfH6SM...\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login/social", "host": ["{{baseUrl}}"], "path": ["auth", "login", "social"] }
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"target\": \"0901234567\",\n  \"type\": \"SMS\",\n  \"purpose\": \"VERIFY_PHONE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/send-otp", "host": ["{{baseUrl}}"], "path": ["auth", "send-otp"] }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"target\": \"0901234567\",\n  \"otp\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["auth", "verify-otp"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["auth", "refresh-token"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
