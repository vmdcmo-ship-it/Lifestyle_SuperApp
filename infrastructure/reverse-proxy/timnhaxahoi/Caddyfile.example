# Mẫu Caddy — timnhaxahoi.com (HTTPS tự động)
# Chạy: caddy run --config /path/Caddyfile
# NEXT_PUBLIC_API_URL=https://timnhaxahoi.com/api/v1
#
# Thứ tự: directive reverse_proxy có matcher đứng trước được ưu tiên (xem tài liệu Caddy reverse_proxy).

timnhaxahoi.com, www.timnhaxahoi.com {
    encode gzip zstd

    # Cùng pattern chính thức trong docs Caddy — mọi path dưới /api/ → Nest (3020).
    reverse_proxy /api/* 127.0.0.1:3020
    reverse_proxy 127.0.0.1:3040

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
    }
}
