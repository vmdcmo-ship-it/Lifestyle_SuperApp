# Sao chép thành `.env` cạnh lệnh compose hoặc truyền `--env-file`.
# Thứ tự triển khai thật: xem docs/timnhaxahoi/DEPLOY_VA_VAN_HANH.md

DASHBOARD_JWT_SECRET=thay-bang-chuoi-dai-ngau-nhien

TIMNHAXAHOI_DB_USER=postgres
# Mật khẩu Postgres: KHÔNG viết ở đây. Tạo file (một dòng chữ):
#   infrastructure/docker/secrets/timnhaxahoi_db_password
# Cách nhanh: cd infrastructure/docker/secrets && cp timnhaxahoi_db_password.example timnhaxahoi_db_password
# Nội dung mẫu là "postgres" — đúng nếu bạn chưa từng đổi mật khẩu DB. Chi tiết: secrets/README.md
TIMNHAXAHOI_DB_NAME=timnhaxahoi
TIMNHAXAHOI_DB_PORT=5433

TIMNHAXAHOI_API_PORT=3020
TIMNHAXAHOI_WEB_PORT=3040

# Trình duyệt gọi API — production: https://timnhaxahoi.com/api/v1 hoặc URL API public
NEXT_PUBLIC_API_URL=http://localhost:3020/api/v1
NEXT_PUBLIC_SITE_URL=https://timnhaxahoi.com

# Header — logo + slogan (bake vào build qua Docker build args)
# NEXT_PUBLIC_SITE_LOGO_URL=
# NEXT_PUBLIC_SITE_SLOGAN=
# NEXT_PUBLIC_SITE_NAME=timnhaxahoi.com

# Tuỳ chọn — Places Autocomplete (hạn chế theo HTTP referrer trong Google Cloud)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Sitemap SSR trong container — gọi API theo tên service (mặc định compose)
# INTERNAL_API_URL=http://timnhaxahoi-api:3020/api/v1

# Sentry (tuỳ chọn) — xem docs/timnhaxahoi/OBSERVABILITY.md
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_DSN=

# Rate limit API (request / window TTL giây)
# THROTTLE_ELIGIBILITY_LIMIT=12
# THROTTLE_ELIGIBILITY_TTL_SEC=60
# THROTTLE_AUTH_SYNC_LIMIT=30
# THROTTLE_AUTH_SYNC_TTL_SEC=60
# THROTTLE_LEADS_CONVERT_LIMIT=20
# THROTTLE_LEADS_CONVERT_TTL_SEC=60

# CORS cho API (danh sách origin, phân tách bằng dấu phẩy)
TIMNHAXAHOI_CORS_ORIGIN=http://localhost:3040,https://timnhaxahoi.com

# Super App — assertion JWT cho POST /auth/sync (tuỳ chọn; bật khi AUTH_SYNC_REQUIRE_JWT=true)
# AUTH_SYNC_JWT_SECRET= (trùng main-api khi HS256)
# AUTH_SYNC_JWT_ISSUER=lifestyle-main-api
# AUTH_SYNC_JWT_AUDIENCE=timnhaxahoi:auth-sync:v1
# AUTH_SYNC_REQUIRE_JWT=false
# AUTH_SYNC_JTI_CHECK=true

# Lark (tuỳ chọn)
# LARK_OPEN_API_BASE=
# LARK_APP_ID=
# LARK_APP_SECRET=
# LARK_BASE_APP_TOKEN=
# LARK_BASE_TABLE_ID=
# LARK_BASE_FIELD_MAP=
# LARK_BASE_SINGLE_TEXT_FIELD_ID=
