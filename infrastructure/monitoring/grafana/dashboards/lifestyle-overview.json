{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "System Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "CPU Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "percent",
          "max": 100
        }
      },
      "targets": [{
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU %"
      }]
    },
    {
      "title": "Memory Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent",
          "max": 100
        }
      },
      "targets": [{
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "Memory %"
      }]
    },
    {
      "title": "Disk Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent",
          "max": 100
        }
      },
      "targets": [{
        "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100",
        "legendFormat": "Disk %"
      }]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "dtdurations" } },
      "targets": [{
        "expr": "node_time_seconds - node_boot_time_seconds",
        "legendFormat": "Uptime"
      }]
    },
    {
      "title": "API Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "title": "HTTP Requests/sec",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [{
        "expr": "sum(rate(lifestyle_http_requests_total[5m]))",
        "legendFormat": "Total RPS"
      }, {
        "expr": "sum(rate(lifestyle_http_requests_total{status_code=~\"2..\"}[5m]))",
        "legendFormat": "2xx"
      }, {
        "expr": "sum(rate(lifestyle_http_requests_total{status_code=~\"4..\"}[5m]))",
        "legendFormat": "4xx"
      }, {
        "expr": "sum(rate(lifestyle_http_requests_total{status_code=~\"5..\"}[5m]))",
        "legendFormat": "5xx"
      }]
    },
    {
      "title": "API Latency (p50, p95, p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{
        "expr": "histogram_quantile(0.50, rate(lifestyle_http_request_duration_seconds_bucket[5m]))",
        "legendFormat": "p50"
      }, {
        "expr": "histogram_quantile(0.95, rate(lifestyle_http_request_duration_seconds_bucket[5m]))",
        "legendFormat": "p95"
      }, {
        "expr": "histogram_quantile(0.99, rate(lifestyle_http_request_duration_seconds_bucket[5m]))",
        "legendFormat": "p99"
      }]
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [{
        "expr": "lifestyle_active_connections",
        "legendFormat": "Active"
      }]
    },
    {
      "title": "Total Requests (24h)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [{
        "expr": "sum(increase(lifestyle_http_requests_total[24h]))",
        "legendFormat": "Requests"
      }]
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(rate(lifestyle_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(lifestyle_http_requests_total[5m]))",
        "legendFormat": "5xx Rate"
      }]
    },
    {
      "title": "Node.js Heap Used",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [{
        "expr": "lifestyle_nodejs_heap_size_used_bytes",
        "legendFormat": "Heap Used"
      }]
    },
    {
      "title": "Database & Cache",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "collapsed": false
    },
    {
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 21 },
      "targets": [{
        "expr": "pg_stat_activity_count",
        "legendFormat": "{{ datname }} - {{ state }}"
      }]
    },
    {
      "title": "Redis Memory Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [{
        "expr": "redis_memory_used_bytes",
        "legendFormat": "Used Memory"
      }, {
        "expr": "redis_memory_max_bytes",
        "legendFormat": "Max Memory"
      }]
    },
    {
      "title": "Redis Commands/sec",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [{
        "expr": "rate(redis_commands_processed_total[5m])",
        "legendFormat": "Commands/s"
      }]
    },
    {
      "title": "Container Resources",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false
    },
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "targets": [{
        "expr": "rate(container_cpu_usage_seconds_total{name=~\"lifestyle_.*\"}[5m]) * 100",
        "legendFormat": "{{ name }}"
      }]
    },
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [{
        "expr": "container_memory_usage_bytes{name=~\"lifestyle_.*\"}",
        "legendFormat": "{{ name }}"
      }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["lifestyle", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Lifestyle Super App - Overview",
  "uid": "lifestyle-overview",
  "version": 1
}
