# ============================================================================
# PRODUCTION ENVIRONMENT VARIABLES - Lifestyle Super App
# ============================================================================
# IMPORTANT: 
# 1. Copy this file to .env.production
# 2. Fill in all values marked with <CHANGE_THIS>
# 3. NEVER commit .env.production to git
# 4. Keep this file secure and backup safely
# ============================================================================

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=production
APP_NAME=Lifestyle SuperApp
APP_VERSION=1.0.0

# ============================================================================
# DOMAIN CONFIGURATION
# ============================================================================
DOMAIN=vmd.asia
API_DOMAIN=api.vmd.asia
AUTH_DOMAIN=auth.vmd.asia

# ============================================================================
# DATABASE - PostgreSQL
# ============================================================================
# SECURITY: Generate strong passwords using: openssl rand -base64 32
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=lifestyle_db
DATABASE_USER=lifestyle_admin
DATABASE_PASSWORD=<CHANGE_THIS_STRONG_PASSWORD>
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# Connection Pool Settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT=30000

# ============================================================================
# REDIS - Cache & Session
# ============================================================================
# SECURITY: Generate strong password using: openssl rand -base64 32
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<CHANGE_THIS_REDIS_PASSWORD>
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}
REDIS_TTL=3600

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# SECURITY: Generate secrets using: openssl rand -hex 64
JWT_SECRET=<CHANGE_THIS_JWT_SECRET_MIN_64_CHARS>
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=<CHANGE_THIS_REFRESH_SECRET_MIN_64_CHARS>
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================================
# API KEYS - Google Services
# ============================================================================
# Get from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=<YOUR_GOOGLE_MAPS_API_KEY>
GOOGLE_OAUTH_CLIENT_ID=<YOUR_GOOGLE_OAUTH_CLIENT_ID>
GOOGLE_OAUTH_CLIENT_SECRET=<YOUR_GOOGLE_OAUTH_CLIENT_SECRET>

# ============================================================================
# FIREBASE - Push Notifications
# ============================================================================
# Get from: https://console.firebase.google.com/
FIREBASE_PROJECT_ID=<YOUR_FIREBASE_PROJECT_ID>
FIREBASE_PRIVATE_KEY=<YOUR_FIREBASE_PRIVATE_KEY>
FIREBASE_CLIENT_EMAIL=<YOUR_FIREBASE_CLIENT_EMAIL>

# ============================================================================
# AWS S3 - File Storage (Optional)
# ============================================================================
# Get from: https://aws.amazon.com/console/
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_KEY>
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=lifestyle-uploads-prod

# ============================================================================
# PAYMENT GATEWAY
# ============================================================================
# Configure based on your payment provider (VNPay, Momo, etc.)
PAYMENT_GATEWAY_API_KEY=<YOUR_PAYMENT_GATEWAY_KEY>
PAYMENT_GATEWAY_SECRET=<YOUR_PAYMENT_GATEWAY_SECRET>
PAYMENT_GATEWAY_MERCHANT_ID=<YOUR_MERCHANT_ID>
PAYMENT_GATEWAY_RETURN_URL=https://vmd.asia/payment/return
PAYMENT_GATEWAY_NOTIFY_URL=https://api.vmd.asia/payment/notify

# VNPay Specific (if using)
VNPAY_TMN_CODE=<YOUR_VNPAY_TMN_CODE>
VNPAY_HASH_SECRET=<YOUR_VNPAY_HASH_SECRET>
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# ============================================================================
# ZALO INTEGRATION
# ============================================================================
# Get from: https://developers.zalo.me/
ZALO_APP_ID=<YOUR_ZALO_APP_ID>
ZALO_APP_SECRET=<YOUR_ZALO_APP_SECRET>
ZALO_OA_ID=<YOUR_ZALO_OA_ID>

# ============================================================================
# EMAIL SERVICE (SMTP)
# ============================================================================
# Gmail example (Enable "Less secure app access" or use App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<YOUR_EMAIL@gmail.com>
SMTP_PASSWORD=<YOUR_APP_PASSWORD>
SMTP_FROM=noreply@vmd.asia
SMTP_FROM_NAME=Lifestyle SuperApp

# ============================================================================
# SMS SERVICE - Twilio (or your provider)
# ============================================================================
# Get from: https://www.twilio.com/console
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=<YOUR_TWILIO_ACCOUNT_SID>
TWILIO_AUTH_TOKEN=<YOUR_TWILIO_AUTH_TOKEN>
TWILIO_PHONE_NUMBER=<YOUR_TWILIO_PHONE>

# Vietnam SMS Provider (Alternative)
VIETGUYS_USERNAME=<YOUR_VIETGUYS_USERNAME>
VIETGUYS_PASSWORD=<YOUR_VIETGUYS_PASSWORD>
VIETGUYS_BRANDNAME=<YOUR_BRANDNAME>

# ============================================================================
# AI/ML SERVICES (Optional)
# ============================================================================
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
AI_SERVICE_URL=http://ai-service:3005

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
# Sentry Error Tracking - Get from: https://sentry.io/
SENTRY_DSN=<YOUR_SENTRY_DSN>
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Datadog APM (Optional) - Get from: https://www.datadoghq.com/
DATADOG_API_KEY=<YOUR_DATADOG_API_KEY>
DATADOG_APP_KEY=<YOUR_DATADOG_APP_KEY>

# Log Level
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ORIGIN=https://vmd.asia,https://www.vmd.asia
CORS_CREDENTIALS=true

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=20

# ============================================================================
# FILE UPLOAD
# ============================================================================
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# Upload destination (local or s3)
UPLOAD_DESTINATION=local
UPLOAD_PATH=/app/uploads

# ============================================================================
# FRONTEND - Next.js Environment
# ============================================================================
# These will be embedded in the client-side bundle (sitemap, canonical, OG)
NEXT_PUBLIC_BASE_URL=https://www.vmd.asia
NEXT_PUBLIC_API_URL=https://api.vmd.asia
NEXT_PUBLIC_WS_URL=wss://api.vmd.asia
NEXT_PUBLIC_AUTH_URL=https://auth.vmd.asia
NEXT_PUBLIC_GOOGLE_MAPS_KEY=${GOOGLE_MAPS_API_KEY}
NEXT_PUBLIC_SENTRY_DSN=${SENTRY_DSN}

# ============================================================================
# SESSION CONFIGURATION
# ============================================================================
SESSION_SECRET=<CHANGE_THIS_SESSION_SECRET>
SESSION_MAX_AGE=86400000  # 24 hours in ms

# ============================================================================
# WEBHOOKS
# ============================================================================
WEBHOOK_SECRET=<CHANGE_THIS_WEBHOOK_SECRET>

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Every day at 2 AM
BACKUP_RETENTION_DAYS=30

# ============================================================================
# SECURITY
# ============================================================================
# Encrypt sensitive data at rest
ENCRYPTION_KEY=<CHANGE_THIS_ENCRYPTION_KEY_32_CHARS>
ENCRYPTION_ALGORITHM=aes-256-gcm

# API Key for internal service-to-service communication
INTERNAL_API_KEY=<CHANGE_THIS_INTERNAL_API_KEY>

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_PAYMENT_ENABLED=true
FEATURE_TRANSPORTATION_ENABLED=true
FEATURE_INSURANCE_ENABLED=false
FEATURE_TRAVEL_ENABLED=false
FEATURE_AI_ENABLED=false

# ============================================================================
# TIMEZONE
# ============================================================================
TZ=Asia/Ho_Chi_Minh

# ============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ============================================================================
# 1. Generate all secrets using secure methods (openssl, uuid, etc.)
# 2. Store this file securely (encrypted backup)
# 3. Use environment variable management tools in production
# 4. Rotate secrets regularly (quarterly recommended)
# 5. Audit access to this file
# 6. Consider using Docker secrets or Kubernetes secrets for sensitive data
# ============================================================================
