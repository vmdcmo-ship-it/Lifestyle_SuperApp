# ============================================================================
# .dockerignore - Lifestyle Super App
# ============================================================================
# Excludes files and directories from Docker build context
# This significantly reduces build time and image size
# ============================================================================

# ============================================================================
# VERSION CONTROL
# ============================================================================
.git
.gitignore
.gitattributes
.github

# ============================================================================
# DEPENDENCIES
# ============================================================================
node_modules
**/node_modules
**/.pnpm
.pnpm-store

# ============================================================================
# BUILD OUTPUTS
# ============================================================================
dist
build
.next
out
**/.next
**/dist
**/build
**/out

# Coverage
coverage
**/coverage
.nyc_output
**/.nyc_output

# ============================================================================
# DEVELOPMENT FILES
# ============================================================================
# IDE
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
*.iml

# Cursor
.cursor

# ============================================================================
# LOGS
# ============================================================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================================================
# ENVIRONMENT & CONFIG
# ============================================================================
.env
.env.*
.env.local
.env.*.local
!.env.example
!.env.production.template

# ============================================================================
# TESTING
# ============================================================================
__tests__
**/__tests__
*.test.ts
*.test.tsx
*.test.js
*.test.jsx
*.spec.ts
*.spec.tsx
*.spec.js
*.spec.jsx
test
tests
**/test
**/tests

# Jest
jest.config.js
jest.config.ts

# ============================================================================
# DOCUMENTATION
# ============================================================================
README.md
CHANGELOG.md
LICENSE
*.md
docs
**/docs
design
plans

# ============================================================================
# DEPLOYMENT & INFRASTRUCTURE
# ============================================================================
infrastructure
!infrastructure/docker
docker-compose.yml
docker-compose.*.yml
!infrastructure/docker/docker-compose.production.yml

Dockerfile
**/Dockerfile
!infrastructure/docker/Dockerfile.*

# Kubernetes
*.yaml
*.yml
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!tsconfig.json

# Terraform
*.tf
*.tfvars
.terraform

# ============================================================================
# CI/CD
# ============================================================================
.circleci
.travis.yml
.gitlab-ci.yml
azure-pipelines.yml
bitbucket-pipelines.yml

# GitHub Actions (keep if needed, otherwise uncomment)
# .github

# ============================================================================
# TEMPORARY FILES
# ============================================================================
tmp
temp
**/tmp
**/temp
*.tmp

# ============================================================================
# BACKUP FILES
# ============================================================================
*.bak
*.backup
*~
*.orig

# ============================================================================
# MOBILE SPECIFIC
# ============================================================================
# React Native
apps/mobile-*/android
apps/mobile-*/ios
apps/mobile-*/.expo
apps/mobile-*/.expo-shared

# ============================================================================
# DATABASE & CACHE
# ============================================================================
*.sqlite
*.sqlite3
*.db
redis-data
postgres-data

# Prisma
prisma/migrations
!prisma/schema.prisma

# ============================================================================
# ASSETS (Large Files)
# ============================================================================
# Uncomment if you don't need these in Docker image
# *.png
# *.jpg
# *.jpeg
# *.gif
# *.svg
# *.mp4
# *.mp3

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================
.vercel
.turbo
**/.turbo

# Bundle analyzer
.next/analyze

# ============================================================================
# MISC
# ============================================================================
# OS
Thumbs.db
Desktop.ini

# Package manager locks (keep pnpm-lock.yaml)
package-lock.json
yarn.lock

# Editor directories
.vscode-test

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache
.cache
.parcel-cache

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# Storybook
storybook-static
**/storybook-static

# ============================================================================
# PROJECT SPECIFIC
# ============================================================================
# Add any project-specific ignores below
uploads
**/uploads
backups
**/backups
