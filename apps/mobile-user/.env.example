# API Base URL for mobile app
# Production: https://api.vmd.asia/api/v1
# Local dev (same WiFi as device): http://YOUR_COMPUTER_IP:3000/api/v1
# Example: http://192.168.1.100:3000/api/v1
EXPO_PUBLIC_API_URL=https://api.vmd.asia/api/v1

# Web app base URL (Shopping Mall, deep links, WebView)
# Production: https://lifestyle-app.com
# Local: http://YOUR_IP:3001 (khi chạy npm run dev --workspace=apps/web)
EXPO_PUBLIC_WEB_BASE_URL=https://lifestyle-app.com
