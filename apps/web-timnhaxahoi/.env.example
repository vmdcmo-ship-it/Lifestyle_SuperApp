NEXT_PUBLIC_SITE_URL=https://timnhaxahoi.com
NEXT_PUBLIC_API_URL=http://localhost:3020/api/v1

# Header — logo + slogan (tuỳ chọn). Không set logo → hiển thị chữ NEXT_PUBLIC_SITE_NAME (mặc định timnhaxahoi.com).
# Logo: URL tuyệt đối (https://...) hoặc đường dẫn public, ví dụ /brand/logo.svg
# NEXT_PUBLIC_SITE_LOGO_URL=
# NEXT_PUBLIC_SITE_SLOGAN=
# NEXT_PUBLIC_SITE_NAME=timnhaxahoi.com

# SSR (sitemap): khi web chạy trong Docker, ưu tiên URL nội bộ tới API
# INTERNAL_API_URL=http://timnhaxahoi-api:3020/api/v1

# Tuỳ chọn — autocomplete địa chỉ (quiz). Hạn chế key theo HTTP referrer trên Google Cloud.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Sentry — xem docs/timnhaxahoi/OBSERVABILITY.md
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# SENTRY_TRACES_SAMPLE_RATE=0
