# Public Environment Variables
# Copy this file to .env.local and fill in your actual values

# Base URL (production domain)
NEXT_PUBLIC_BASE_URL=https://lifestyle-app.com

# Google Analytics Measurement ID
# GA4 format: G-XXXXXXXXXX
# Universal Analytics format: UA-XXXXXXXXX-X
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Site Verification (for Search Console)
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-verification-code-here

# API Endpoints
# Local dev (main-api): http://localhost:3000
# Production: https://api.vmd.asia
NEXT_PUBLIC_API_URL=http://localhost:3000

# App Store Links (for CTA section on homepage - update when app is published)
# Format: https://apps.apple.com/app/lifestyle-super-app/idXXXXXXXX
# Format: https://play.google.com/store/apps/details?id=com.lifestyle.superapp
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/lifestyle-super-app/id0000000000
NEXT_PUBLIC_GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=com.lifestyle.superapp

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SENTRY=false

# OpenAI API (for Chat/AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Other Services
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_MAPBOX_TOKEN=
# NEXT_PUBLIC_FIREBASE_CONFIG=
