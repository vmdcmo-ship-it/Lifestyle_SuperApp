{
  "name": "@lifestyle/web",
  "version": "1.0.0",
  "private": true,
  "description": "Lifestyle Super App - Web Application",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out node_modules",
    "generate-favicons": "node scripts/generate-favicons.mjs"
  },
  "dependencies": {
    "@lifestyle/api-client": "workspace:*",
    "@lifestyle/constants": "workspace:*",
    "@lifestyle/design-system": "workspace:*",
    "@lifestyle/shared": "workspace:*",
    "@lifestyle/types": "workspace:*",
    "@lifestyle/utils": "workspace:*",
    "@lifestyle/validation": "workspace:*",
    "ai": "^3.4.0",
    "axios": "^1.6.7",
    "clsx": "^2.1.1",
    "next": "^14.2.0",
    "openai": "^4.67.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.35",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
